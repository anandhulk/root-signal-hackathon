APP_NAME=<The name of the app>
NODE_ENV=<The node environemnt. Can be set as 'dev'>
SERVER_PORT=<The server port used, can be set as '3000'>
FRONTEND_URL=<The URL of the frontend, e.g. http://localhost:3001. Used for CORS.>

# OpenAI
OPENAI_API_KEY=<Your OpenAI API key. Required for the AI investigation service.>

# AWS (used by CloudWatch and ECS MCP tools)
AWS_ACCESS_KEY_ID=<AWS access key ID>
AWS_SECRET_ACCESS_KEY=<AWS secret access key>
AWS_REGION=<AWS region, e.g. eu-west-1>

# Bitbucket (used by Bitbucket MCP tools)
BITBUCKET_TOKEN=<Bitbucket app password or OAuth 2.0 API token>
BITBUCKET_WORKSPACE=<Default Bitbucket workspace slug>
BITBUCKET_USERNAME=<Bitbucket username — optional. If set, Basic auth is used; otherwise Bearer token.>
