{
  "name": "root-signal-api",
  "version": "0.0.1",
  "description": "Root Signal API",
  "main": "dist/index.js",
  "scripts": {
    "type-check": "eslint . --ext .ts && tsc --noEmit",
    "validate-code": "npm run type-check",
    "prod:compile": "npm run type-check && rm -rf dist/src && babel src --out-dir dist/src --extensions \".ts,.tsx\" --copy-files && npm run mcp:compile",
    "dev:compile": "npm run type-check && rm -rf dist/src && babel src --out-dir dist/src --extensions \".ts,.tsx\" --source-maps inline --copy-files && npm run mcp:compile",
    "mcp:compile": "npm run type-check && rm -rf dist/mcp && babel mcp --out-dir dist/mcp --extensions \".ts,.tsx\" --copy-files",
    "start": "node dist/src/index.js",
    "dev": "pm2 start dev.config.js"
  },
  "keywords": [
    "root-signal",
    "api"
  ],
  "author": "anandhu@mozilor.com",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-cloudwatch": "^3.1024.0",
    "@aws-sdk/client-cloudwatch-logs": "^3.1024.0",
    "@aws-sdk/client-ecs": "^3.1024.0",
    "@modelcontextprotocol/sdk": "^1.10.2",
    "axios": "^1.9.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^5.1.0",
    "ignore": "^7.0.5",
    "moment": "^2.30.1",
    "mysql2": "^3.14.1",
    "openai": "^6.33.0",
    "winston": "^3.11.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@babel/cli": "^7.23.4",
    "@babel/core": "^7.23.7",
    "@babel/preset-env": "^7.23.8",
    "@babel/preset-typescript": "^7.23.3",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.2",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^6.18.1",
    "@typescript-eslint/parser": "^6.18.1",
    "pm2": "^5.3.0",
    "typescript": "^5.3.3"
  }
}
